{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/twixtor-archive run build",
  "outputDirectory": "artifacts/twixtor-archive/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dramavers-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
