# ============================================
# DATABASE — Supabase Postgres
# ============================================
# Ambil di: Supabase Dashboard > Project kamu > Connect > Connection string
# Pilih mode "Session pooler" (port 5432) biar cocok dipakai di VPS/Pterodactyl.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ============================================
# SUPABASE — Auth
# ============================================
# Ambil di: Supabase Dashboard > Project Settings > Data API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Ambil di: Supabase Dashboard > Project Settings > API Keys > anon / public
SUPABASE_ANON_KEY=

# Ambil di: Supabase Dashboard > Project Settings > API Keys > service_role
# JANGAN pernah expose key ini ke frontend/publik — ini punya akses penuh.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# CLOUDFLARE R2 — Storage (video, foto, thumbnail)
# ============================================
# Ambil di: Cloudflare Dashboard > R2 > Overview (pojok kanan, "Account ID")
CLOUDFLARE_R2_ACCOUNT_ID=

# Ambil di: Cloudflare Dashboard > R2 > Manage API Tokens > Create API Token
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Nama bucket yang kamu buat di R2 (contoh: dramaverse-media)
CLOUDFLARE_R2_BUCKET_NAME=

# Public URL bucket. Aktifkan dulu "Public Access" di setting bucket R2,
# atau pasang custom domain — nanti ada URL kayak: https://pub-xxxxxxxx.r2.dev
CLOUDFLARE_R2_PUBLIC_URL=

# ============================================
# LAINNYA
# ============================================
PORT=3000
NODE_ENV=production
ADMIN_USERNAME=rapp
ADMIN_PASSWORD=ganti_password_ini
